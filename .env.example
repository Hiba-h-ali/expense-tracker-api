# Copy to .env for local dev. On Railway, set these in the service Variables tab.

# DB: omit for local SQLite; add Railway Postgres and use the provided DATABASE_URL
# DATABASE_URL=postgresql://...
# JWT_SECRET=replace-with-long-random-secret
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_MINUTES=30
# REFRESH_TOKEN_DAYS=14
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://your-flutter-web-host

# Gemini (optional; expense categorization falls back if unset)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Google CES agent (only if you use app/agent_client.py flows)
# GOOGLE_CLOUD_PROJECT_ID=
# CES_APP_ID=
# CES_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
